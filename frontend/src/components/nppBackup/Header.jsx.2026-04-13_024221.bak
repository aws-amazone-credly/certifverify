import { Link } from "react-router-dom";
import { useAuth } from "../context/AuthContext";
import toast from "react-hot-toast";

export default function Header() {
  const { authed, logout } = useAuth();

  function handleLogout() {
    logout();
    toast.success("Déconnecté");
  }

  return (
    <header className="bg-white border-b border-slate-200 sticky top-0 z-50">
      <div className="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
        <Link to="/" className="flex items-center gap-2">
          <span className="text-2xl">🔐</span>
          <span className="font-display font-bold text-xl text-brand-700">CertVerify</span>
        </Link>

        <nav className="flex items-center gap-4 text-sm font-medium">
          <Link to="/" className="text-slate-600 hover:text-brand-600 transition-colors">
            Vérifier
          </Link>
          {authed ? (
            <>
              <Link to="/admin" className="text-slate-600 hover:text-brand-600 transition-colors">
                Dashboard
              </Link>
              <Link to="/admin/templates" className="text-slate-600 hover:text-brand-600 transition-colors">
                Certifications
              </Link>
              <button
                onClick={handleLogout}
                className="ml-2 px-4 py-1.5 rounded-lg text-red-600 border border-red-200 hover:bg-red-50 transition-colors"
              >
                Déconnexion
              </button>
            </>
          ) : (
            <Link
              to="/admin/login"
              className="px-4 py-1.5 rounded-lg bg-brand-500 text-white hover:bg-brand-600 transition-colors"
            >
              Admin
            </Link>
          )}
        </nav>
      </div>
    </header>
  );
}
