import { QRCodeSVG } from "qrcode.react";

function StatusBadge({ valid, cert }) {
  if (!valid && cert?.status === "revoked")
    return <span className="px-3 py-1 rounded-full text-xs font-semibold badge-revoked">Révoqué</span>;
  if (!valid && cert?.expiresAt)
    return <span className="px-3 py-1 rounded-full text-xs font-semibold badge-expired">Expiré</span>;
  if (!valid)
    return <span className="px-3 py-1 rounded-full text-xs font-semibold badge-revoked">Introuvable</span>;
  return <span className="px-3 py-1 rounded-full text-xs font-semibold badge-valid">✓ Valide</span>;
}

function formatDate(val) {
  if (!val) return "—";
  const d = val?.toDate ? val.toDate() : new Date(val._seconds ? val._seconds * 1000 : val);
  return d.toLocaleDateString("fr-FR", { day: "2-digit", month: "long", year: "numeric" });
}

export default function CertCard({ result }) {
  const { valid, cert, message } = result;

  return (
    <div className={`rounded-2xl border-2 p-8 max-w-2xl mx-auto bg-white shadow-lg
      ${valid ? "border-green-300" : "border-red-200"}`}>

      {/* Header statut */}
      <div className="flex items-center gap-3 mb-6">
        <span className="text-4xl">{valid ? "✅" : "❌"}</span>
        <div>
          <p className="text-slate-500 text-sm">Résultat de la vérification</p>
          <StatusBadge valid={valid} cert={cert} />
        </div>
        {message && <p className="ml-auto text-sm text-slate-500 italic">{message}</p>}
      </div>

      {!cert && (
        <p className="text-center text-slate-400 py-8">Aucune donnée disponible pour ce code.</p>
      )}

      {cert && (
        <div className="grid grid-cols-1 sm:grid-cols-3 gap-6">
          {/* Badge */}
          <div className="flex flex-col items-center justify-center gap-3">
            {cert.badgeUrl ? (
              <img src={cert.badgeUrl} alt="badge" className="w-24 h-24 object-contain" />
            ) : (
              <div className="w-24 h-24 rounded-full bg-brand-50 border-2 border-brand-200 flex items-center justify-center text-4xl">
                🏅
              </div>
            )}
            <p className="text-xs text-slate-400 text-center">{cert.certificationName}</p>
          </div>

          {/* Infos */}
          <div className="sm:col-span-1 space-y-3 text-sm">
            <div>
              <p className="text-xs text-slate-400 uppercase tracking-wide">Bénéficiaire</p>
              <p className="font-semibold text-slate-800">{cert.recipientName}</p>
            </div>
            <div>
              <p className="text-xs text-slate-400 uppercase tracking-wide">Email</p>
              <p className="text-slate-600">{cert.recipientEmail}</p>
            </div>
            <div>
              <p className="text-xs text-slate-400 uppercase tracking-wide">Émis le</p>
              <p className="text-slate-600">{formatDate(cert.issuedAt)}</p>
            </div>
            {cert.expiresAt && (
              <div>
                <p className="text-xs text-slate-400 uppercase tracking-wide">Expire le</p>
                <p className="text-slate-600">{formatDate(cert.expiresAt)}</p>
              </div>
            )}
            <div>
              <p className="text-xs text-slate-400 uppercase tracking-wide">Code</p>
              <p className="font-mono text-brand-600 text-xs">{cert.verifyCode}</p>
            </div>
          </div>

          {/* QR Code */}
          <div className="flex flex-col items-center gap-2">
            <QRCodeSVG
              value={`${window.location.origin}${window.location.pathname}#/verify/${cert.verifyCode}`}
              size={96}
              className="rounded"
            />
            <p className="text-xs text-slate-400">Scanner pour vérifier</p>
          </div>
        </div>
      )}
    </div>
  );
}
