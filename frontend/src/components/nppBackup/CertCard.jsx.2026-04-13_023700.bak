import { useEffect, useRef } from "react";
import QRCodeStyling from "qr-code-styling";

// --- Badge de statut du certificat ---
function StatusBadge({ valid, cert }) {
  if (!valid && cert?.status === "revoked")
    return <span className="px-3 py-1 rounded-full text-xs font-semibold badge-revoked">Revoked</span>;
  if (!valid && cert?.expiresAt)
    return <span className="px-3 py-1 rounded-full text-xs font-semibold badge-expired">Expired</span>;
  if (!valid)
    return <span className="px-3 py-1 rounded-full text-xs font-semibold badge-revoked">Not Found</span>;
  return <span className="px-3 py-1 rounded-full text-xs font-semibold badge-valid">✓ Valid</span>;
}

// --- Formate un timestamp Firestore ou une date JS en date lisible ---
function formatDate(val) {
  if (!val) return "—";
  const d = val?.toDate ? val.toDate() : new Date(val._seconds ? val._seconds * 1000 : val);
  return d.toLocaleDateString("en-US", { day: "2-digit", month: "long", year: "numeric" });
}

// --- Composant QR Code avec logo central via qr-code-styling ---
function CertQRCode({ verifyCode, logoUrl }) {
  const ref = useRef(null);
  const qrRef = useRef(null);

  useEffect(() => {
    // Construction de l'URL de vérification encodée dans le QR
    const verifyUrl = `${window.location.origin}${window.location.pathname}#/verify/${verifyCode}`;

    // Initialisation de l'instance qr-code-styling avec les options de style
    qrRef.current = new QRCodeStyling({
      width: 100,
      height: 100,
      data: verifyUrl,
      // Logo au centre : badge du certificat si disponible, sinon aucun
      image: logoUrl || undefined,
      dotsOptions: {
        color: "#4F46E5",       // couleur principale des points (violet brand)
        type: "rounded",        // forme arrondie pour un rendu moderne
      },
      cornersSquareOptions: {
        type: "extra-rounded",  // coins très arrondis pour adoucir le QR
      },
      imageOptions: {
        crossOrigin: "anonymous",
        margin: 3,              // espace entre le logo et les points
        imageSize: 0.3,         // logo occupe 30% de la surface
      },
      backgroundOptions: {
        color: "#ffffff",
      },
    });

    // Injection du QR dans le DOM
    if (ref.current) {
      ref.current.innerHTML = "";
      qrRef.current.append(ref.current);
    }
  }, [verifyCode, logoUrl]);

  return (
    <div className="flex flex-col items-center gap-2">
      {/* Conteneur du QR généré dynamiquement */}
      <div ref={ref} className="rounded overflow-hidden" />
      <p className="text-xs text-slate-400">Scan to verify</p>
    </div>
  );
}

// --- Carte principale affichant les détails d'un certificat ---
export default function CertCard({ result }) {
  const { valid, cert, message } = result;

  return (
    <div className={`rounded-2xl border-2 p-8 max-w-2xl mx-auto bg-white shadow-lg
      ${valid ? "border-green-300" : "border-red-200"}`}>

      {/* En-tête : icône de statut + badge + message optionnel */}
      <div className="flex items-center gap-3 mb-6">
        <span className="text-4xl">{valid ? "✅" : "❌"}</span>
        <div>
          <p className="text-slate-500 text-sm">Verification result</p>
          <StatusBadge valid={valid} cert={cert} />
        </div>
        {message && <p className="ml-auto text-sm text-slate-500 italic">{message}</p>}
      </div>

      {/* Cas : aucun certificat trouvé */}
      {!cert && (
        <p className="text-center text-slate-400 py-8">No data available for this code.</p>
      )}

      {/* Cas : certificat trouvé — affichage en 3 colonnes */}
      {cert && (
        <div className="grid grid-cols-1 sm:grid-cols-3 gap-6">

          {/* Colonne 1 : badge visuel du certificat */}
          <div className="flex flex-col items-center justify-center gap-3">
            {cert.badgeUrl ? (
              <img src={cert.badgeUrl} alt="badge" className="w-24 h-24 object-contain" />
            ) : (
              // Fallback emoji si pas d'image de badge
              <div className="w-24 h-24 rounded-full bg-brand-50 border-2 border-brand-200 flex items-center justify-center text-4xl">
                🏅
              </div>
            )}
            <p className="text-xs text-slate-400 text-center">{cert.certificationName}</p>
          </div>

          {/* Colonne 2 : informations textuelles du certificat */}
          <div className="sm:col-span-1 space-y-3 text-sm">
            <div>
              <p className="text-xs text-slate-400 uppercase tracking-wide">Recipient</p>
              <p className="font-semibold text-slate-800">{cert.recipientName}</p>
            </div>
            <div>
              <p className="text-xs text-slate-400 uppercase tracking-wide">Email</p>
              <p className="text-slate-600">{cert.recipientEmail}</p>
            </div>
            <div>
              <p className="text-xs text-slate-400 uppercase tracking-wide">Issued on</p>
              <p className="text-slate-600">{formatDate(cert.issuedAt)}</p>
            </div>
            {/* Date d'expiration affichée uniquement si présente */}
            {cert.expiresAt && (
              <div>
                <p className="text-xs text-slate-400 uppercase tracking-wide">Expires on</p>
                <p className="text-slate-600">{formatDate(cert.expiresAt)}</p>
              </div>
            )}
            <div>
              <p className="text-xs text-slate-400 uppercase tracking-wide">Code</p>
              <p className="font-mono text-brand-600 text-xs">{cert.verifyCode}</p>
            </div>
          </div>

          {/* Colonne 3 : QR code avec logo du badge en centre */}
          <CertQRCode
            verifyCode={cert.verifyCode}
            logoUrl={cert.badgeUrl}   // réutilise le badge comme logo du QR
          />
        </div>
      )}
    </div>
  );
}