import { useState } from "react";
import { useNavigate } from "react-router-dom";
import Header from "../components/Header";

export default function Home() {
  const [code, setCode] = useState("");
  const navigate = useNavigate();

  // --- Soumission du formulaire : redirige vers la page de vérification ---
  function handleVerify(e) {
    e.preventDefault();
    const trimmed = code.trim();
    if (trimmed) navigate(`/verify/${trimmed}`);
  }

  // --- Cartes de fonctionnalités affichées sous la barre de recherche ---
  const features = [
    { icon: "⚡", label: "Instant",   desc: "Results in under a second" },
    { icon: "🔒", label: "Reliable",  desc: "Data secured on Firebase" },
    { icon: "📱", label: "QR Code",   desc: "Scan directly from the badge" },
  ];

  return (
    <div className="min-h-screen flex flex-col">
      <Header />

      {/* Section principale centrée verticalement */}
      <main className="flex-1 flex flex-col items-center justify-center px-4 text-center">
        <div className="max-w-2xl w-full space-y-6">

          {/* Titre et description */}
          <div className="space-y-3">
            <span className="text-6xl">🔐</span>
            <h1 className="font-display font-bold text-[14px] sm:text-[14px] text-slate-900 leading-tight">
              Verify the authenticity<br />of an IT certification
            </h1>
            <p className="text-slate-500 text-lg">
              Enter the verification code printed on the certificate
              to confirm its authenticity in seconds.
            </p>
          </div>

          {/* Barre de recherche du code de vérification */}
          <form onSubmit={handleVerify} className="flex gap-2 max-w-lg mx-auto">
            <input
              type="text"
              value={code}
              onChange={(e) => setCode(e.target.value)}
              placeholder="e.g. V3rK2mXpQ8nL"
              className="flex-1 px-4 py-3 rounded-xl border border-slate-300 focus:outline-none
                         focus:ring-2 focus:ring-brand-400 font-mono text-sm bg-white"
            />
            <button
              type="submit"
              disabled={!code.trim()}
              className="px-6 py-3 rounded-xl bg-brand-500 text-white font-semibold
                         hover:bg-brand-600 disabled:opacity-40 disabled:cursor-not-allowed transition-colors"
            >
              Verify
            </button>
          </form>

          {/* Grille des 3 cartes de fonctionnalités */}
          <div className="grid grid-cols-1 sm:grid-cols-3 gap-4 pt-8 text-sm">
            {features.map(({ icon, label, desc }) => (
              <div key={label} className="bg-white rounded-xl border border-slate-200 p-4 text-center">
                <span className="text-2xl">{icon}</span>
                <p className="font-semibold text-slate-800 mt-1">{label}</p>
                <p className="text-slate-500 text-xs mt-1">{desc}</p>
              </div>
            ))}
          </div>
        </div>
      </main>

      {/* Pied de page */}
      <footer className="text-center text-xs text-slate-400 py-6">
        © {new Date().getFullYear()} CertVerify — IT Certification Verification Platform 
      </footer>
    </div>
  );
}